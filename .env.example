# API
API_PORT=8000

# MySQL service
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=vendor_market
MYSQL_USER=app
MYSQL_PASSWORD=change-me-app-password

# API database connection (uses the mysql service name from docker-compose)
DATABASE_URL=mysql+pymysql://app:change-me-app-password@mysql:3306/vendor_market

# JWT secret – generate your own with:  openssl rand -hex 32
SECRET_KEY=change-me-jwt-secret
